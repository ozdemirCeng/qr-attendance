# Vercel API project template (Root Directory: apps/api)
# Add these values in Vercel -> Project Settings -> Environment Variables.

NODE_ENV=production
API_PORT=3001

# Database
DATABASE_URL=

# Optional Redis for nonce store and async workloads
REDIS_URL=

# QR security
QR_SECRET=replace-with-a-strong-random-secret-min-32-chars
QR_ROTATION_SECONDS=60

# CORS (must be your web domain)
CORS_ORIGIN=https://qr-attendance-web.vercel.app

# Optional monitoring
SENTRY_DSN=

# Optional Neon Auth proxy
NEON_AUTH_BASE_URL=

# Auth cookie
AUTH_COOKIE_NAME=session
PARTICIPANT_COOKIE_NAME=participant_session

# Optional demo fallback credentials
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_USERNAME=demoadmin
DEMO_ADMIN_EMAIL=demo.admin@qrattendance.local
DEMO_ADMIN_PASSWORD=replace-with-a-strong-random-demo-password
