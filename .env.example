# Neon Postgres
DATABASE_URL=

# Redis (Upstash/Redis compatible)
REDIS_URL=

# QR security
QR_SECRET=replace-with-a-strong-random-secret-min-32-chars
QR_ROTATION_SECONDS=60

# API runtime (deploy)
API_PORT=3001
CORS_ORIGIN=https://your-web-domain.vercel.app
SENTRY_DSN=

# Auth proxy (Neon Auth)
NEON_AUTH_BASE_URL=
AUTH_COOKIE_NAME=session

# Web runtime (deploy)
NEXT_PUBLIC_API_URL=https://your-api-domain.vercel.app
API_INTERNAL_URL=https://your-api-domain.vercel.app

# Demo credentials
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_USERNAME=demoadmin
DEMO_ADMIN_EMAIL=demo.admin@qrattendance.local
DEMO_ADMIN_PASSWORD=replace-with-a-strong-random-demo-password
